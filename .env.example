# Environment label used by local scripts to prevent running dev-only Prisma
# commands against production. Use "development" locally and "production" in
# Vercel Production.
PAGEFORGE_ENV="development"

# Supabase Postgres connection strings.
# Local development should point at the pageforge-dev Supabase project.
# Vercel Production should point at the pageforge-prod Supabase project.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[URL_ENCODED_PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[URL_ENCODED_PASSWORD]@[POOLER_HOST]:5432/postgres"

# Supabase Auth/browser client values for the same project as DATABASE_URL.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUPABASE_ANON_KEY]"
