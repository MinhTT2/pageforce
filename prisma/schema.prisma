generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum SectionMode {
  INHERIT
  CUSTOM
  HIDDEN
}

model Site {
  id           String   @id @default(cuid())
  userId       String
  name         String
  slug         String   @unique
  globalHeader Json?
  globalFooter Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  pages        Page[]

  @@index([userId])
}

model Page {
  id              String     @id @default(cuid())
  userId          String
  siteId          String
  title           String
  slug            String
  legacySlug      String?    @unique
  isHome          Boolean    @default(false)
  status          PageStatus @default(DRAFT)
  draftSchema     Json
  publishedSchema Json?
  headerMode      SectionMode @default(INHERIT)
  footerMode      SectionMode @default(INHERIT)
  headerSchema    Json?
  footerSchema    Json?
  publishedAt     DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  leadSubmissions LeadSubmission[]

  @@index([userId])
  @@index([siteId])
  @@index([status, slug])
  @@unique([siteId, slug])
}

model LeadSubmission {
  id        String   @id @default(cuid())
  pageId    String
  blockId   String
  data      Json
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
}
