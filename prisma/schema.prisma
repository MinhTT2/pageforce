generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum SectionMode {
  INHERIT
  HIDDEN
}

model Site {
  id              String           @id @default(cuid())
  userId          String
  name            String
  slug            String           @unique
  globalHeader    Json?
  globalFooter    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  pages           Page[]
  leadSubmissions LeadSubmission[]

  @@index([userId])
}

model Page {
  id              String     @id @default(cuid())
  siteId          String
  title           String
  slug            String
  isHome          Boolean    @default(false)
  status          PageStatus @default(DRAFT)
  schema          Json        @map("draftSchema")
  headerMode      SectionMode @default(INHERIT)
  footerMode      SectionMode @default(INHERIT)
  publishedAt     DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([status, slug])
  @@unique([siteId, slug])
}

model LeadSubmission {
  id        String   @id @default(cuid())
  siteId    String
  blockId   String
  data      Json
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
}
